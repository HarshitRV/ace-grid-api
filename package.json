{
    "name": "ace-grid-api",
    "version": "0.0.1",
    "description": "ace grid api",
    "main": "dist/app.js",
    "engines": {
        "node": ">=24.14.0",
        "npm": ">=11.9.0"
    },
    "scripts": {
        "dev": "env-cmd tsx watch src/app.ts",
        "prod": "env-cmd -f .env.production tsx watch src/app.ts",
        "build": "tsc && tsc-alias",
        "start": "node --env-file=.env dist/app.js",
        "lint": "eslint src --ext .ts",
        "test": "jest",
        "seed": "tsx src/scripts/seed.ts"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/node": "^25.5.0",
        "env-cmd": "^11.0.0",
        "eslint": "^10.0.3",
        "globals": "^17.4.0",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0"
    },
    "dependencies": {
        "bcryptjs": "^3.0.3",
